  "type": "project",
  "keywords": [
    "novel",
    "thinkphp"
  ],
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "rick",
      "email": "rick9403@gmail.com"
    }
  ],
  "require": {
    "php": ">=5.6.0",
    "topthink/framework": "5.1.32",
    "topthink/think-captcha": "2.*",
    "topthink/think-image": "^1.0",
    "ext-gd": "*",
    "ext-iconv": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-json": "*",
    "topthink/think-migration": "^2.0"
